# Flask Configuration
SECRET_KEY=your_secret_key_here_change_this_to_a_long_random_string

# Database Configuration (optional)
# Leave empty to use local SQLite, or set to PostgreSQL URL for Render
DATABASE_URL=

# MongoDB Configuration (optional)
# Set this to your MongoDB Atlas connection string for user profiles and logs
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/placement_prediction?appName=ML

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False

# Application Settings
LOG_LEVEL=INFO
